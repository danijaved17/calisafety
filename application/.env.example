# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub

# PostgreSQL — local development
# For Railway: copy the connection string from your Railway project dashboard
DATABASE_URL=postgresql://user:password@localhost:5432/calisafety

# Firebase — from your Firebase project settings
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=

# Google Maps — restrict this key to your domain in Google Cloud Console
GOOGLE_MAPS_API_KEY=
